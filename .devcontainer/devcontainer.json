{
  "name": "Valory Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/home/valory/workspace",
  "remoteUser": "valory",
  "forwardPorts": [8443, 5432, 5173],
  "portsAttributes": {
    "8443": { "label": "API (TLS)", "onAutoForward": "notify" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" },
    "5173": { "label": "Vite Dev Server", "onAutoForward": "openBrowser" }
  },
  "postCreateCommand": "[ -f /home/valory/workspace/backend/go.mod ] && cd /home/valory/workspace/backend && go mod download; [ -f /home/valory/workspace/frontend/package.json ] && cd /home/valory/workspace/frontend && npm ci; true",
  "remoteEnv": {
    "GOPATH": "/home/valory/go",
    "PATH": "${containerEnv:PATH}:/home/valory/go/bin"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "Vue.volar",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ],
      "settings": {
        "go.toolsManagement.checkForUpdates": "local",
        "go.useLanguageServer": true,
        "[go]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "golang.go"
        },
        "[vue]": {
          "editor.defaultFormatter": "Vue.volar"
        },
        "[typescript]": {
          "editor.defaultFormatter": "Vue.volar"
        }
      }
    }
  }
}
