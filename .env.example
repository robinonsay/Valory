# Anthropic Claude API
ANTHROPIC_API_KEY=your-key-here

# Brave Search API (used by Professor agents for content generation)
BRAVE_API_KEY=your-key-here

# Database
DB_PASSWORD=changeme
DATABASE_URL=postgres://valory_app:changeme@db:5432/valory?sslmode=disable

# TLS — leave ACME_DOMAIN empty for development (self-signed cert is generated automatically)
ACME_DOMAIN=
ACME_CACHE_DIR=/app/acme-cache

# Session
SESSION_SECRET=changeme
SESSION_TIMEOUT_SECONDS=1800

# Agent pipeline
AGENT_RETRY_LIMIT=3
CORRECTION_LOOP_MAX=5
CONTENT_GENERATION_TIMEOUT_SECONDS=300

# Storage
UPLOADS_DIR=/app/uploads
